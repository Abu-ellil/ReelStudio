{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors 'self' https://YOUR-BLOG.blogspot.com;"
        },
        {
          "key": "X-Frame-Options",
          "value": "ALLOW-FROM https://YOUR-BLOG.blogspot.com"
        }
      ]
    }
  ]
}
